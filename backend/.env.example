# Copie este arquivo para .env e preencha os valores

# Porta do servidor (Railway define automaticamente)
PORT=3001

# JWT - Gere uma string aleatória longa para produção
JWT_SECRET=troque_por_string_aleatoria_com_32_caracteres

# URL do frontend no Vercel (preencher após deploy do frontend)
# Exemplo: https://cardapio-digital.vercel.app
FRONTEND_URL=

# Informações do restaurante
RESTAURANT_NAME=Sabor do Chef
RESTAURANT_WHATSAPP=5511999999999
